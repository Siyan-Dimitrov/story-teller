# OpenAI GPT Image backend
# Copy this file to .env and set your key locally. .env is ignored by git.
# gpt-image-2 requires a verified OpenAI organization:
# https://platform.openai.com/settings/organization/general
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=2048x1152
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_BACKGROUND=auto
OPENAI_IMAGE_TIMEOUT_SECONDS=240
OPENAI_IMAGE_DELAY_SECONDS=12
